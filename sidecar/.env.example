# Engine behavior
RESEARCHER_SIDECAR_ENGINE=open_deep_research

# Open Deep Research model configuration.
# Use provider strings accepted by LangChain init_chat_model.
RESEARCHER_RESEARCH_MODEL=openai:gpt-4.1
RESEARCHER_SUMMARIZATION_MODEL=openai:gpt-4.1-mini
RESEARCHER_COMPRESSION_MODEL=openai:gpt-4.1
RESEARCHER_FINAL_REPORT_MODEL=openai:gpt-4.1

# Search backend. Open Deep Research commonly uses Tavily by default.
RESEARCHER_SEARCH_API=tavily

# Runtime limits
RESEARCHER_MAX_ITERATIONS=4
RESEARCHER_MAX_TOOL_CALLS=8
RESEARCHER_MAX_CONCURRENCY=4

# Provider/search credentials live in the Python environment, not in vault JSON.
# OPENAI_API_KEY=
# TAVILY_API_KEY=
# ANTHROPIC_API_KEY=

{
  "name": "obsidian-plugin",
  "version": "0.0.0",
  "description": "AI OS plugin for Obsidian — proactive surfacing + deep research.",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --external:obsidian --format=cjs --target=es2020 --outfile=main.js",
    "dev": "esbuild src/main.ts --bundle --external:obsidian --format=cjs --target=es2020 --outfile=main.js --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

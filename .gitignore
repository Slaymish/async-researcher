.claude/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node / TS
node_modules/
.pnpm-store/
dist/
*.tsbuildinfo

# Obsidian plugin build output
obsidian-plugin/main.js

# Local config & secrets (per ADR-0016)
config.toml
config.local.toml
.env
.env.local

# Local data (per ADR-0017 storage path)
*.duckdb
*.duckdb.wal

# Eval snapshots can be large
eval/harness/snapshots/*
!eval/harness/snapshots/.gitkeep

# Experiments are throwaway
experiments/*
!experiments/.gitkeep

# Editor
.DS_Store
.idea/
.vscode/
*.pem
